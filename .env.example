# =========================================================================
# Aura Routes Platform Next.js Frontend - Environment Configuration Example
# =========================================================================

# Base URL of the FastAPI Backend
NEXT_PUBLIC_API_URL=http://localhost:8000

# WhatsApp contact number (with country code, no spaces or dashes, e.g., +919876543210)
NEXT_PUBLIC_WHATSAPP_NUMBER=+919891263337

# Calendly URL (e.g., https://calendly.com/your-profile/consultation)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/aura-routes/consultation

# Supabase Auth & Storage API access (For student register/login and file uploads)
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-ID].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-client-side-key-id

# Razorpay Checkout Public Key (For opening payment overlays in checkout pages)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_YourRazorpayKeyId
